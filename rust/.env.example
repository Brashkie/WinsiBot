# winsibot-session-api v3 — configuración
# Copia a .env y edita

PORT=3001
API_KEY=genera_con_openssl_rand_-hex_32
SESSIONS_DIR=./sessions

# Nivel de logs: error | warn | info | debug | trace
RUST_LOG=winsibot_session_api=info,tower_http=info

# ── Variables para WinsiBot v8 (agregar a tu .env del bot) ──
SESSION_API_URL=http://127.0.0.1:3001
SESSION_API_KEY=la_misma_API_KEY_de_arriba
