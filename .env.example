# Bot
PREFIX=!
BOT_NAME=WinsiBot
OWNER_JID=51999999999@s.whatsapp.net
SESSION_PATH=./auth

# APIs externas
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Ollama (IA local — gratis, sin API key, primera opción antes de GPT/Claude/Gemini)
# Requiere tener Ollama corriendo: https://ollama.com — luego `ollama pull llama3.2:3b`
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=25

# Rule34 (opcional — comandos nsfw/rule34*, funcionan sin esto pero con límites más bajos)
RULE34_API_KEY=
RULE34_USER_ID=

# Xbox Live / OpenXBL (opcional — comandos mcsearch/mcfriends/mcachievement)
# Conseguí tu propia key gratis en https://xbl.io/ (login con tu cuenta Xbox)
XBL_API_KEY=

# Python API
PYTHON_API_URL=http://localhost:5000

# Rust Session API (winsibot-session-api)
SESSION_API_URL=http://127.0.0.1:3001
SESSION_API_KEY=

# Webhook receiver (opcional, puerto distinto al de Rust)
WEBHOOK_PORT=4001
WEBHOOK_SECRET=winsibot_secret

# PHP API
PHP_API_URL=http://localhost:8080

# Base de datos
DATABASE_URL=postgresql://winsi:password@localhost:5432/winsibot

# Redis
REDIS_URL=redis://localhost:6379

# Misc
NODE_ENV=development
LOG_LEVEL=info