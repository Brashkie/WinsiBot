{
  "name": "winsi-bot",
  "version": "8.5.1",
  "description": "WinsiBot v8.5.1 — High-performance WhatsApp bot with multi-language architecture (TypeScript + Rust + Python), advanced AI, RPG economy, and resilience for very active groups (Baileys no longer drops batched messages after a reconnect, Rust's rate limiter and Bad MAC tracker moved to DashMap for real concurrency, Bad MAC history actually persists, fast NLP path no longer panics). Adds Dragon City (replaces the old pet system), BrasEmbers, Businesses, and free Spotify alternatives.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/supervisor.js",
    "start:unsupervised": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "node scripts/setup.js",
    "status": "node scripts/status.js",
    "monitor": "node scripts/monitor.js",
    "manage": "node scripts/manage.js",
    "manage:status": "node scripts/manage.js status",
    "manage:diagnose": "node scripts/manage.js diagnose",
    "manage:repair": "node scripts/manage.js repair",
    "manage:reset-signal": "node scripts/manage.js reset-signal",
    "manage:reset-qr": "node scripts/manage.js reset-qr",
    "manage:backup": "node scripts/manage.js backup",
    "manage:restore": "node scripts/manage.js restore",
    "manage:logs": "node scripts/manage.js logs",
    "api": "node scripts/api.js",
    "celery": "node scripts/celery.js",
    "redis": "redis-cli ping",
    "redis:server": "node scripts/redis.js",
    "services": "concurrently \"npm run api\" \"npm run celery\"",
    "build": "tsc && tsc-alias",
    "php:dev": "cd php && php -S localhost:8080 -t public public/index.php",
    "php:prod": "cd php && php -S 0.0.0.0:8080 -t public public/index.php",
    "cython:build": "powershell scripts/build_cython.ps1",
    "cython:clean": "rimraf python/cython_ext/*.so python/cython_ext/*.pyd python/cython_ext/build",
    "spam:build": "node scripts/spam_build.js",
    "rust:build": "cd rust && cargo build --release",
    "rust:start": "cd rust && cargo run --release",
    "lint": "biome lint src/ scripts/",
    "lint:fix": "biome lint --write src/ scripts/",
    "format": "biome format src/ scripts/",
    "format:fix": "biome format --write src/ scripts/",
    "check": "biome check src/ scripts/",
    "check:fix": "biome check --write src/ scripts/",
    "rust:lint": "cd rust && cargo clippy --release",
    "py:lint": "node scripts/py_lint.js",
    "py:lint:fix": "node scripts/py_lint.js --fix",
    "py:format": "node scripts/py_format.js",
    "lint:all": "npm run lint && npm run rust:lint && npm run py:lint",
    "qr": "node dist/index.js qr",
    "code": "node dist/index.js code",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "health": "node scripts/health.js",
    "ai:test": "node scripts/ai_test.js"
  },
  "homepage": "https://github.com/Brashkie/WinsiBot",
  "author": {
    "name": "Hepein Oficial",
    "email": "support@hepein.dev",
    "url": "https://hepein.dev"
  },
  "directories": {
    "lib": "src/lib",
    "src": "src",
    "plugins": "src/plugins",
    "database": "src/database"
  },
  "keywords": [
    "whatsapp-bot",
    "typescript",
    "baileys-md",
    "multi-device",
    "openai",
    "cluster",
    "fast",
    "performance",
    "ai",
    "hepein",
    "music",
    "scraper",
    "bot"
  ],
  "bugs": {
    "url": "https://github.com/Brashkie/WinsiBot/issues"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@brashkie/signalis-core": "^0.4.0",
    "@hapi/boom": "^9.1.3",
    "@msgpack/msgpack": "^3.1.3",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@vitalets/google-translate-api": "^9.2.0",
    "@whiskeysockets/baileys": "^6.7.18",
    "ansimax": "^1.4.5",
    "axios": "^1.7.3",
    "axios-retry": "^4.2.1",
    "better-sqlite3": "^11.3.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "eventemitter3": "^5.0.1",
    "fast-glob": "^3.3.2",
    "file-type": "^19.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "moment-timezone": "^0.5.45",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "rimraf": "^6.0.1",
    "wa-sticker-formatter": "^4.3.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/better-sqlite3": "^7.6.11",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^2.1.3",
    "nodemon": "^3.1.10",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0",
    "sharp": "^0.34.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
