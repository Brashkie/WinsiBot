{
  "name": "winsi-bot",
  "version": "8.1.1",
  "description": "WinsiBot v8.1.0 — Bot de WhatsApp ultra optimizado en TypeScript, modular, rápido, eficiente y con IA avanzada.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "monitor": "node scripts/monitor.js",
    "manage": "node scripts/manage.js",
    "manage:status": "node scripts/manage.js status",
    "manage:diagnose": "node scripts/manage.js diagnose",
    "manage:repair": "node scripts/manage.js repair",
    "manage:reset-signal": "node scripts/manage.js reset-signal",
    "manage:reset-qr": "node scripts/manage.js reset-qr",
    "manage:backup": "node scripts/manage.js backup",
    "manage:restore": "node scripts/manage.js restore",
    "manage:logs": "node scripts/manage.js logs",
    "flask": "node scripts/flask.js",
    "celery": "node scripts/celery.js",
    "redis": "redis-cli ping",
    "services": "concurrently \"npm run redis\" \"npm run flask\" \"npm run celery\"",
    "build": "tsc",
    "php:dev": "cd php && php -S localhost:8080 -t public public/index.php",
    "php:prod": "cd php && php -S 0.0.0.0:8080 -t public public/index.php",
    "cython:build": "powershell scripts/build_cython.ps1",
    "cython:clean": "rimraf python/cython_ext/*.so python/cython_ext/*.pyd python/cython_ext/build",
    "spam:build": "node scripts/spam_build.js",
    "rust:build": "cd rust && cargo build --release",
    "rust:start": "cd rust && cargo run --release",
    "start:all": "concurrently \"npm run rust:start\" \"npm run monitor\" \"npm run php:dev\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint --fix . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "qr": "node dist/index.js qr",
    "code": "node dist/index.js code",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "health": "node scripts/health.js",
    "ai:test": "node scripts/ai_test.js"
  },
  "homepage": "https://github.com/Brashkie/WinsiBot",
  "author": {
    "name": "Hepein Oficial",
    "email": "support@hepein.dev",
    "url": "https://hepein.dev"
  },
  "directories": {
    "lib": "src/lib",
    "src": "src",
    "plugins": "src/plugins",
    "database": "src/database"
  },
  "keywords": [
    "whatsapp-bot",
    "typescript",
    "baileys-md",
    "multi-device",
    "openai",
    "cluster",
    "fast",
    "performance",
    "ai",
    "hepein",
    "music",
    "scraper",
    "bot"
  ],
  "bugs": {
    "url": "https://github.com/Brashkie/WinsiBot/issues"
  },
  "license": "GPL-3.0-or-later",
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@bochilteam/scraper": "^4.2.4",
    "@brandond/findthelyrics": "^2.0.5",
    "@ibaraki-douji/pixivts": "^3.2.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@tobyg74/tiktok-api-dl": "^1.3.7",
    "@vitalets/google-translate-api": "^9.2.0",
    "@whiskeysockets/baileys": "^6.7.18",
    "ansimax": "^1.2.6",
    "apache-arrow": "^17.0.0",
    "archiver": "^7.0.1",
    "arquero": "^5.4.0",
    "axios": "^1.7.3",
    "axios-retry": "^4.2.1",
    "better-sqlite3": "^11.3.0",
    "boxen": "^8.0.1",
    "bullmq": "^5.13.0",
    "cheerio": "^1.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.33.0",
    "eventemitter3": "^5.0.1",
    "express": "^5.0.1",
    "fast-glob": "^3.3.2",
    "file-type": "^19.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "formdata-node": "^6.0.0",
    "genius-lyrics": "^4.4.6",
    "hispamemes": "^1.0.7",
    "imagemaker.js": "^2.0.4",
    "instagram-url-direct": "^2.0.7",
    "ioredis": "^5.4.1",
    "moment-timezone": "^0.5.45",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "p-limit": "^6.1.0",
    "p-queue": "^8.0.1",
    "pdfkit": "^0.15.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.4",
    "pretty-bytes": "^6.1.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "rimraf": "^6.0.1",
    "ruhend-scraper": "^10.0.1",
    "socket.io": "^4.7.2",
    "ts-pattern": "^5.2.0",
    "url-file-size": "^1.0.5",
    "uuid": "^13.0.0",
    "wa-sticker-formatter": "^4.3.2",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0",
    "sharp": "^0.34.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
